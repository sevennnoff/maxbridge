# Номер телефона аккаунта MAX в международном формате.
PHONE=

# Токен Telegram-бота от BotFather.
BOT_TOKEN=

# true — пересылать сообщения из Telegram в MAX, false — не пересылать.
FORWARD_TG_TO_MAX=true

# JSON-словарь: "id чата MAX" -> id чата Telegram.
# Пример с несколькими чатами:
# CHATS={"-10000000000000": -1000000000000, "-20000000000000": -2000000000000}
CHATS={"-10000000000000": -1000000000000}
